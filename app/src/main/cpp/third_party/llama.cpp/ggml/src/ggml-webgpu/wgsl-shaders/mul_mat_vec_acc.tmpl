                        let l       = slot0 + ll;
                        let qs_byte = get_byte(qs_w, l);
                        let ig      = (qs_byte | (((qh >> (3u * l)) & 7u) << 8u)) * 8u;
                        let gw      = iq1_grid[ig / 16u];
                        let bit_base = (ig % 16u) * 2u;
                        for (var j = 0u; j < 8u; j++) {
