                        sums[3] += x_block[col][l + 12u] * dq3;
                    }

                    acc[col][row] += d * (sums[0] * f32(sc0) + sums[1] * f32(sc2) +
                                    sums[2] * f32(sc4) + sums[3] * f32(sc6));
                }
            }
        }
