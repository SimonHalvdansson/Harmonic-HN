<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <PreferenceCategory
        app:title="Comments display"
        android:layout="@layout/preference_category">

        <com.simon.harmonichackernews.settings.CommentDisplayStylePreference
            app:defaultValue="standard"
            app:key="pref_comment_display_style"
            app:title="Display style" />

        <SwitchPreferenceCompat
            app:defaultValue="true"
            app:icon="@drawable/ic_select"
            app:key="pref_comment_card_border"
            app:singleLineTitle="false"
            app:title="Border" />

        <com.simon.harmonichackernews.settings.CommentTextSizePreference
            app:defaultValue="15"
            app:key="pref_comment_text_size"
            app:title="Text size" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_collect_links_in_comments"
            app:defaultValue="true"
            app:icon="@drawable/ic_link"
            app:title="Collect links in comments" />

        <Preference
            app:singleLineTitle="false"
            app:key="pref_comment_depth_indicators"
            app:icon="@drawable/ic_palette"
            app:title="Thread depth indicators" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_top_level_thread_indicators"
            app:icon="@drawable/ic_format_align_left"
            app:defaultValue="false"
            app:summary="Makes it easier to separate top level comments"
            app:title="Show top level thread indicators" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_comments_scrollbar"
            app:defaultValue="false"
            app:icon="@drawable/ic_swipe_vertical"
            app:title="Show scrollbar" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_comments_animation"
            app:defaultValue="true"
            app:icon="@drawable/ic_animation"
            app:title="Animate comment expand/collapse" />

    </PreferenceCategory>

    <PreferenceCategory
        app:title="Header display"
        android:layout="@layout/preference_category">

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_enable_comments_header_tint"
            app:defaultValue="true"
            app:icon="@drawable/ic_palette"
            app:title="Background tint" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_enable_comments_header_preview_image"
            app:defaultValue="true"
            app:icon="@drawable/ic_image"
            app:title="Preview image" />

    </PreferenceCategory>

    <PreferenceCategory
        app:title="Interaction"
        android:layout="@layout/preference_category">

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_collapse_parent"
            app:icon="@drawable/ic_comment"
            app:title="Hide text of collapsed comments" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            android:defaultValue="false"
            app:key="pref_collapse_top_level"
            app:icon="@drawable/ic_minimize"
            app:title="Auto-collapse top level comments" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_comments_swap_long"
            app:defaultValue="false"
            app:summaryOn="Current: Tap for options"
            app:summaryOff="Current: Tap to hide/expand"
            app:icon="@drawable/ic_touch_app"
            app:title="Swap tap/long press behavior" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_comments_disable_swipeback"
            app:defaultValue="true"
            app:icon="@drawable/ic_swipe"
            app:title="Disable swipe back from comments" />

        <ListPreference
            app:singleLineTitle="false"
            app:icon="@drawable/ic_filter_list"
            app:title="Comment sorting"
            app:key="pref_comment_sorting"
            app:useSimpleSummaryProvider="true"
            app:entries="@array/comment_sorting"
            app:defaultValue="Default"
            app:entryValues="@array/comment_sorting" />

        <ListPreference
            app:singleLineTitle="false"
            app:key="pref_comments_provider"
            app:icon="@drawable/ic_api"
            app:title="Comments provider"
            app:useSimpleSummaryProvider="true"
            app:entries="@array/comments_provider_entries"
            app:defaultValue="algolia"
            app:entryValues="@array/comments_provider_values" />

    </PreferenceCategory>

    <PreferenceCategory
        app:title="Navigation"
        android:layout="@layout/preference_category">

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_scroll_navigation"
            app:icon="@drawable/ic_explore"
            app:title="Show navigation buttons"
            app:summary="Navigate between top level comments"
            app:defaultValue="false" />

        <ListPreference
            app:singleLineTitle="false"
            app:key="pref_comments_volume_navigation"
            app:defaultValue="disabled"
            app:icon="@drawable/ic_swipe_vertical"
            app:title="Volume buttons for navigation"
            app:entries="@array/comments_volume_navigation_entries"
            app:entryValues="@array/comments_volume_navigation_values"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            app:singleLineTitle="false"
            app:key="pref_comments_animation_navigation"
            app:defaultValue="true"
            app:icon="@drawable/ic_comments_animation_navigation"
            app:title="Smooth scroll comments" />

    </PreferenceCategory>

</PreferenceScreen>
