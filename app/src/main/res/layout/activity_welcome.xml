<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/welcome_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/welcome_bottom_action_scroll_padding">

        <LinearLayout
            android:paddingLeft="@dimen/single_view_side_margin"
            android:paddingRight="@dimen/single_view_side_margin"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:paddingTop="40dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_gravity="center_vertical"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginRight="16dp"
                    android:contentDescription="Harmonic app icon"
                    android:src="@mipmap/ic_launcher" />

                <TextView
                    android:id="@+id/welcome_title"
                    android:textColor="?attr/storyColorNormal"
                    android:textStyle="bold"
                    android:fontFamily="@font/product_sans"
                    android:textSize="28sp"
                    android:text="Welcome to Harmonic for Hacker News!"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <TextView
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:textSize="16sp"
                android:fontFamily="@font/product_sans"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Before we get started, you can change some options here to customize the app to your liking."/>

            <TextView
                android:id="@+id/welcome_theme_header"
                android:layout_marginTop="14dp"
                android:text="Theme:"
                android:textStyle="bold"
                android:textSize="18sp"
                android:paddingBottom="4dp"
                android:textColor="?attr/storyColorNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    android:id="@+id/welcome_button_material_daynight"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_gravity="right"
                    android:layout_weight="1"
                    android:tag="material_daynight"
                    android:text="Material You (auto)"
                    android:textColor="?attr/storyColorNormal" />

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/welcome_button_material_dark"
                    android:textColor="?attr/storyColorNormal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_gravity="right"
                    android:tag="material_dark"
                    android:text="Material You (dark)"/>

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/welcome_button_material_light"
                    android:textColor="?attr/storyColorNormal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_gravity="right"
                    android:tag="material_light"
                    android:text="Material You (light)"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/welcome_button_dark"
                    android:textColor="?attr/storyColorNormal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_gravity="right"
                    android:tag="dark"
                    android:text="Dark"/>

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/welcome_button_gray"
                    android:textColor="?attr/storyColorNormal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:layout_gravity="right"
                    android:tag="gray"
                    android:text="Gray"/>

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/welcome_button_black"
                    android:textColor="?attr/storyColorNormal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_gravity="right"
                    android:tag="amoled"
                    android:text="Black"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/welcome_button_light"
                    android:textColor="?attr/storyColorNormal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_gravity="right"
                    android:tag="light"
                    android:text="Light"/>

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/welcome_button_hacker_news"
                    android:textColor="?attr/storyColorNormal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:layout_marginRight="8dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_gravity="right"
                    android:tag="hacker_news"
                    android:text="HN"/>

                <Button
                    android:fontFamily="@font/product_sans_bold"
                    style="?attr/materialButtonOutlinedStyle"
                    android:id="@+id/welcome_button_white"
                    android:textColor="?attr/storyColorNormal"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginLeft="8dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:layout_gravity="right"
                    android:tag="white"
                    android:text="White"/>

            </LinearLayout>

            <TextView
                android:textColor="?attr/textColorDisabled"
                android:text="Preview"
                android:fontFamily="@font/product_sans"
                android:textStyle="bold"
                android:textSize="13dp"
                android:textAllCaps="true"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/welcome_story_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <include
                    android:id="@+id/story_list_item"
                    layout="@layout/story_list_item" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_marginTop="12dp"
                android:text="Preview images:"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?attr/storyColorNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/welcome_story_preview_image_mode_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/welcome_story_preview_image_mode_off"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:fontFamily="@font/product_sans_bold"
                    android:text="Off"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/welcome_story_preview_image_mode_small"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:fontFamily="@font/product_sans_bold"
                    android:text="Small"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/welcome_story_preview_image_mode_large"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checkable="true"
                    android:fontFamily="@font/product_sans_bold"
                    android:text="Large"
                    android:textAllCaps="false" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:layout_marginTop="12dp"
                android:text="Quick settings:"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?attr/storyColorNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/welcome_switch_thumbnails"
                android:drawableLeft="@drawable/ic_action_web"
                android:drawablePadding="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans"
                android:textSize="16sp"
                android:checked="true"
                android:text="Thumbnails"   />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/welcome_switch_tint"
                android:drawableLeft="@drawable/ic_action_colors"
                android:drawablePadding="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans"
                android:textSize="16sp"
                android:text="Tint" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/welcome_switch_points"
                android:drawableLeft="@drawable/ic_action_thumbs"
                android:drawablePadding="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans"
                android:textSize="16sp"
                android:checked="true"
                android:text="Points"   />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/welcome_switch_index"
                android:drawableLeft="@drawable/ic_action_index"
                android:drawablePadding="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans"
                android:textSize="16sp"
                android:checked="true"
                android:text="Indices"   />

            <TextView
                android:paddingTop="6dp"
                android:textSize="15sp"
                android:visibility="visible"
                android:text="Harmonic has a large collection of additional settings which you should explore after getting used to the app, including font changes, link previews, preloading, filters and much more."
                android:fontFamily="@font/product_sans"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/welcome_get_started_fab"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:backgroundTint="?attr/colorSecondary"
        android:elevation="4dp"
        android:fontFamily="@font/product_sans"
        android:onClick="done"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:text="Get started"
        android:textAllCaps="false"
        android:textColor="?attr/colorOnSecondary"
        android:textStyle="bold"
        app:icon="@drawable/ic_action_check"
        app:iconTint="?attr/colorOnSecondary" />

</FrameLayout>
