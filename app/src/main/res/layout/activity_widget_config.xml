<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/product_sans"
        android:text="Configure Widget"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Choose which feed to display"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/widget_config_feed_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp">

        <RadioButton
            android:id="@+id/widget_config_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Top Stories"
            android:textSize="16sp"
            android:checked="true" />

        <RadioButton
            android:id="@+id/widget_config_new"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="New Stories"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/widget_config_best"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Best Stories"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/widget_config_ask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Ask HN"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/widget_config_show"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Show HN"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/widget_config_jobs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="Jobs"
            android:textSize="16sp" />

    </RadioGroup>

    <Button
        android:id="@+id/widget_config_confirm"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/product_sans"
        android:text="Confirm"
        android:textAllCaps="false" />

</LinearLayout>
