<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/user_error"
            android:visibility="gone"
            android:orientation="vertical"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="36dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:gravity="center"
                android:paddingTop="24dp"
                android:paddingBottom="6dp"
                android:paddingRight="24dp"
                android:paddingLeft="24dp"
                android:fontFamily="@font/product_sans"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="?attr/storyColorNormal"
                android:text="Loading failed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"    />

            <com.google.android.material.button.MaterialButton
                android:fontFamily="@font/product_sans_bold"
                android:textSize="14sp"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                app:iconPadding="8dp"
                style="@style/Widget.Material3Expressive.Button.IconButton.Outlined"
                app:icon="@drawable/ic_refresh"
                android:id="@+id/user_retry"
                android:textColor="?attr/colorOnSecondary"
                app:iconTint="?attr/colorOnSecondary"
                android:backgroundTint="?attr/colorSecondary"
                android:text="Retry"    />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/user_container"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/user_name"
                android:fontFamily="@font/product_sans_bold"
                android:textColor="?attr/storyColorNormal"
                android:textSize="28sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="intrepidher"/>

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/user_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:importantForAccessibility="noHideDescendants"
                app:shimmer_base_alpha="0.15"
                app:shimmer_base_color="?attr/drawableColor"
                app:shimmer_duration="2000"
                app:shimmer_highlight_alpha="0.17">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <View
                        android:layout_width="196dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/smooth_rectangle_drawable" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="16dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/smooth_rectangle_drawable" />

                    <View
                        android:layout_width="220dp"
                        android:layout_height="16dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/smooth_rectangle_drawable" />

                </LinearLayout>

            </com.facebook.shimmer.ShimmerFrameLayout>

            <LinearLayout
                android:id="@+id/user_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/user_meta"
                    android:fontFamily="@font/product_sans_bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:textColor="?attr/textColorDefault"
                    tools:text="466 karma since Oct 18, 2019"/>

                <org.sufficientlysecure.htmltextview.HtmlTextView
                    android:id="@+id/user_about"
                    android:textColor="?attr/textColorDefault"
                    tools:text="Electrical engineer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/product_sans" />

            </LinearLayout>

            <Button
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                style="@style/Widget.Material3Expressive.Button.IconButton.Outlined"
                app:icon="@drawable/ic_forum"
                app:iconTint="?attr/storyColorNormal"
                android:id="@+id/user_submissions_button"
                android:fontFamily="@font/product_sans_bold"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:textColor="?attr/storyColorNormal"
                android:text="Submissions" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/user_notifications_button"
                style="@style/Widget.Material3Expressive.Button.IconButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/product_sans_bold"
                android:text="Activate notifications"
                android:textColor="?attr/storyColorNormal"
                android:textSize="14sp"
                android:visibility="gone"
                app:icon="@drawable/ic_notifications"
                app:iconTint="?attr/storyColorNormal"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/user_notifications_explanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/product_sans"
                android:text="Get notifications when someone replies to your comments or comments on your stories."
                android:textColor="?attr/storyColorDisabled"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/user_notifications_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:indeterminate="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/user_notifications_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/product_sans"
                android:textColor="?attr/storyColorDisabled"
                android:textSize="13sp"
                android:visibility="gone"
                tools:text="Reply notifications are active." />

            <Button
                android:fontFamily="@font/product_sans_bold"
                app:icon="@drawable/ic_sell"
                android:minWidth="10dp"
                android:layout_marginTop="8dp"
                android:id="@+id/user_tag_button"
                style="@style/Widget.Material3Expressive.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/storyColorNormal"
                android:text="Set tag" />

            <Button
                android:fontFamily="@font/product_sans_bold"
                app:icon="@drawable/ic_block"
                android:minWidth="10dp"
                android:id="@+id/user_block_button"
                style="@style/Widget.Material3Expressive.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/storyColorNormal"
                android:text="Block" />

            <Button
                android:fontFamily="@font/product_sans_bold"
                app:icon="@drawable/ic_flag"
                android:id="@+id/user_report_button"
                style="@style/Widget.Material3Expressive.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/storyColorNormal"
                android:text="Report (email HN)" />


        </LinearLayout>

    </LinearLayout>

</ScrollView>
