<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="24dp"
    android:paddingRight="24dp"
    android:paddingBottom="24dp">

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/debug_notifications_username_layout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Username">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/debug_notifications_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/debug_notifications_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/product_sans"
        android:minHeight="20dp"
        android:textColor="?attr/storyColorDisabled"
        android:textSize="13sp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/debug_notifications_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:indeterminate="true"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/debug_notifications_test"
        style="@style/Widget.Material3Expressive.Button.IconButton.Outlined"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:fontFamily="@font/product_sans_bold"
        android:text="Test notification"
        android:textColor="?attr/storyColorNormal"
        android:textSize="14sp"
        app:icon="@drawable/ic_notifications"
        app:iconTint="?attr/storyColorNormal" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/debug_notifications_enable"
        style="@style/Widget.Material3Expressive.Button.IconButton.Outlined"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:fontFamily="@font/product_sans_bold"
        android:text="Activate"
        android:textColor="?attr/storyColorNormal"
        android:textSize="14sp"
        app:icon="@drawable/ic_notifications"
        app:iconTint="?attr/storyColorNormal" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/debug_notifications_disable"
        style="@style/Widget.Material3Expressive.Button.IconButton.Outlined"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:fontFamily="@font/product_sans_bold"
        android:text="Turn off"
        android:textColor="?attr/storyColorNormal"
        android:textSize="14sp"
        android:visibility="gone"
        app:icon="@drawable/ic_close"
        app:iconTint="?attr/storyColorNormal" />

</LinearLayout>
