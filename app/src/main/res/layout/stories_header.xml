<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/stories_header_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clipToPadding="false"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="24dp"
    android:background="?android:attr/windowBackground"
    app:layout_scrollFlags="scroll|enterAlways|snap">
    <!-- paddingTop applied dynamically via window insets -->

    <LinearLayout
        android:id="@+id/stories_header_toolbar_row"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/stories_header_spinner_container"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatSpinner
                android:layout_marginRight="-10dp"
                android:id="@+id/stories_header_spinner"
                android:dropDownVerticalOffset="49dp"
                android:spinnerMode="dropdown"
                android:popupBackground="@drawable/stories_dropdown_popup_background"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"    />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/stories_header_search_container"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="56dp">

            <com.google.android.material.search.SearchBar
                android:id="@+id/stories_header_search_bar"
                style="@style/Widget.App.StoriesSearchBar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Search posts"
                android:elevation="0dp" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/stories_header_search_edittext"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@android:color/transparent"
                android:elevation="1dp"
                android:fontFamily="@font/product_sans"
                android:hint="Search posts"
                android:imeOptions="actionSearch|flagNoExtractUi"
                android:inputType="textCapSentences"
                android:textColor="?attr/textColorHighlighted"
                android:textColorHint="?attr/textColorDisabled"
                android:singleLine="true" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/stories_header_actions_container"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_marginEnd="-4dp"
                android:layout_width="48dp"
                android:layout_height="48dp">

                <ImageButton
                    android:id="@+id/stories_header_search_button"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Search"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/stories_header_close_search_button"
                    android:visibility="gone"
                    android:src="@drawable/ic_close"
                    android:contentDescription="Close search"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </FrameLayout>

            <ImageButton
                android:id="@+id/stories_header_more"
                android:layout_marginEnd="-12dp"
                android:src="@drawable/ic_more_vert"
                android:contentDescription="More options"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_width="48dp"
                android:layout_height="48dp"    />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/stories_header_user_item_filter_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        app:checkedButton="@id/stories_header_user_item_filter_both"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stories_header_user_item_filter_stories"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checkable="true"
            android:fontFamily="@font/product_sans_bold"
            android:text="Stories"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stories_header_user_item_filter_both"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checkable="true"
            android:fontFamily="@font/product_sans_bold"
            android:text="Both"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stories_header_user_item_filter_comments"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checkable="true"
            android:fontFamily="@font/product_sans_bold"
            android:text="Comments"
            android:textAllCaps="false" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <LinearLayout
        android:id="@+id/stories_header_front_date_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stories_header_front_previous_day"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="Previous front page day"
            android:fontFamily="@font/product_sans_bold"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:textAllCaps="false"
            app:icon="@drawable/ic_chevron_left"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stories_header_front_date"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:contentDescription="Select front page day"
            android:fontFamily="@font/product_sans_bold"
            android:singleLine="true"
            android:textAllCaps="false"
            app:icon="@drawable/ic_calendar_today" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stories_header_front_next_day"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="Next front page day"
            android:fontFamily="@font/product_sans_bold"
            android:minWidth="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:textAllCaps="false"
            app:icon="@drawable/ic_chevron_right"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/stories_header_search_options_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:visibility="gone">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/stories_header_search_options"
            style="@style/Widget.Material3.ChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/stories_header_search_sort_chip"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/stories_header_search_date_chip"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/stories_header_search_points_chip"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/stories_header_search_comments_chip"
                style="@style/Widget.Material3.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/stories_header_search_only_clicked_chip"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From history"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                app:checkedIcon="@drawable/ic_check_control_normal"
                app:checkedIconVisible="true" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <TextView
        android:id="@+id/stories_header_last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/product_sans"
        android:gravity="center"
        android:paddingTop="4dp"
        android:textColor="?attr/textColorDisabled"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/stories_header_cache_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:accessibilityLiveRegion="polite"
        android:fontFamily="@font/product_sans"
        android:gravity="center"
        android:text="Caching stories"
        android:textColor="?attr/textColorDisabled"
        android:textSize="12sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/stories_header_cache_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:contentDescription="Caching stories"
        android:indeterminate="false"
        android:visibility="gone"
        app:trackCornerRadius="3dp"
        app:trackThickness="6dp" />

    <RelativeLayout
        android:id="@+id/stories_header_loading_indicator"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_weight="1">

        <com.google.android.material.loadingindicator.LoadingIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            app:indicatorSize="42dp"
            android:layout_marginTop="36dp"
            android:indeterminate="true" />

    </RelativeLayout>

    <LinearLayout
        android:id="@+id/stories_header_search_empty_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="56dp"
        android:orientation="vertical">

        <ImageView
            android:src="@drawable/ic_search"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:layout_width="match_parent"
            android:layout_height="48dp"    />

        <TextView
            android:visibility="visible"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="36dp"
            android:fontFamily="@font/product_sans"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/textColorHighlighted"
            android:text="No results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"    />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/stories_header_no_bookmarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="56dp"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/stories_header_no_bookmarks_icon"
            android:src="@drawable/ic_bookmark"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:layout_width="match_parent"
            android:layout_height="48dp"    />

        <TextView
            android:id="@+id/stories_header_no_bookmarks_text"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="36dp"
            android:fontFamily="@font/product_sans"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/textColorHighlighted"
            android:text="No bookmarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"    />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/stories_header_loading_failed"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="48dp"
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">

        <ImageView
            android:src="@drawable/ic_cloud_off"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:layout_width="match_parent"
            android:layout_height="56dp"/>

        <TextView
            android:id="@+id/stories_header_loading_failed_text"
            android:gravity="center"
            android:paddingTop="2dp"
            android:paddingBottom="14dp"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:fontFamily="@font/product_sans"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/textColorHighlighted"
            android:text="Loading failed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"    />

        <TextView
            android:id="@+id/stories_header_loading_failed_algolia"
            android:visibility="gone"
            android:paddingBottom="6dp"
            android:paddingRight="24dp"
            android:paddingLeft="24dp"
            android:paddingTop="6dp"
            android:fontFamily="@font/product_sans"
            android:textSize="17sp"
            android:textColor="?attr/storyColorNormal"
            android:text="API Server error: This is most likely due to the Algolia Hacker News API which Harmonic uses being down. Historically, outages for the Algolia API are limited to a few hours but they can last longer."
            android:layout_width="match_parent"
            android:layout_height="wrap_content"    />

        <Button
            android:fontFamily="@font/product_sans_bold"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            style="@style/Widget.Material3Expressive.Button.ElevatedButton"
            app:icon="@drawable/ic_refresh"
            android:textColor="?attr/colorOnSecondary"
            app:iconTint="?attr/colorOnSecondary"
            android:backgroundTint="?attr/colorSecondary"
            android:id="@+id/stories_header_retry_button"
            android:text="Retry"    />

        <Button
            android:fontFamily="@font/product_sans_bold"
            android:id="@+id/stories_header_show_cached"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            style="@style/Widget.Material3Expressive.Button.ElevatedButton"
            app:icon="@drawable/ic_library_books"
            android:textColor="?attr/colorOnSecondary"
            app:iconTint="?attr/colorOnSecondary"
            android:backgroundTint="?attr/colorSecondary"
            android:text="Show cached stories" />

    </LinearLayout>

</LinearLayout>
