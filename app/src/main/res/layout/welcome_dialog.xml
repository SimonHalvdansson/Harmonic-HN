<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:overScrollMode="ifContentScrolls">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="20dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/welcome_dialog_logo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceHarmonicCircle" />

        <TextView
            android:id="@+id/welcome_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/google_sans_flex_rounded"
            android:gravity="center"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/welcome_dialog_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/google_sans_flex_rounded"
            android:text="I hope you'll love the app and feel how much care was put into creating it. If you have an issue or want to submit a PR, you can visit the GitHub repository.\n\nBefore we get started you can select a UI preset below."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/welcome_dialog_story_preview_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clipToOutline="true">

            <include
                android:id="@+id/welcome_dialog_story_preview"
                layout="@layout/story_list_item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />

        </FrameLayout>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/welcome_dialog_preset_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:checkedButton="@id/welcome_dialog_preset_expressive"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/welcome_dialog_preset_expressive"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checkable="true"
                android:fontFamily="@font/google_sans_flex_rounded"
                android:text="Expressive"
                android:textAllCaps="false"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/welcome_dialog_preset_clean"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checkable="true"
                android:fontFamily="@font/product_sans"
                android:text="Simple"
                android:textAllCaps="false"
                android:textStyle="bold" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/welcome_dialog_settings_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/google_sans_flex_rounded"
            android:text="There are a ton of customization options beyond this available in the settings for you to explore."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/welcome_dialog_get_started"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="?attr/colorSecondary"
            android:fontFamily="@font/product_sans"
            android:text="Get started"
            android:textAllCaps="false"
            android:textColor="?attr/colorOnSecondary"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
