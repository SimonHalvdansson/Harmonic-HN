<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_model_item_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="4dp"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="92dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="92dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="13dp"
            android:paddingEnd="64dp"
            android:paddingBottom="13dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="24dp"
                    android:layout_height="24dp">

                    <TextView
                        android:id="@+id/ai_model_item_provider_fallback"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/ai_model_provider_icon_background"
                        android:fontFamily="@font/product_sans_bold"
                        android:gravity="center"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp" />

                    <ImageView
                        android:id="@+id/ai_model_item_provider_icon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/favicon_thumbnail_background"
                        android:clipToOutline="true"
                        android:contentDescription="@null"
                        android:scaleType="fitCenter"
                        android:visibility="invisible" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ai_model_item_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:fontFamily="@font/product_sans_bold"
                        android:maxLines="3"
                        android:textColor="?attr/storyColorNormal"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/ai_model_item_id"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="middle"
                        android:fontFamily="@font/jetbrains_mono"
                        android:maxLines="1"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/ai_model_item_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="34dp"
                android:layout_marginTop="7dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/ai_model_item_free"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="34dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/ai_model_free_badge"
                android:fontFamily="@font/product_sans_bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="@string/ai_model_free_badge"
                android:textColor="?attr/colorOnSecondaryContainer"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/ai_model_item_selected"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="8dp"
            android:clickable="false"
            android:focusable="false" />

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
