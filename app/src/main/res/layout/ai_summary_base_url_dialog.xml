<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/ai_summary_base_url_presets_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/product_sans_bold"
            android:paddingTop="4dp"
            android:text="Presets"
            android:textColor="?attr/storyColorNormal"
            android:textSize="14sp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/ai_summary_base_url_presets"
            style="@style/Widget.Material3.ChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:singleLine="false"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="0dp"
            app:selectionRequired="false"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/ai_summary_base_url_openai"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                android:text="OpenAI"
                app:checkedIcon="@drawable/ic_check_control_normal"
                app:checkedIconVisible="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/ai_summary_base_url_anthropic"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                android:text="Anthropic"
                app:checkedIcon="@drawable/ic_check_control_normal"
                app:checkedIconVisible="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/ai_summary_base_url_openrouter"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                android:text="OpenRouter"
                app:checkedIcon="@drawable/ic_check_control_normal"
                app:checkedIconVisible="true" />

        </com.google.android.material.chip.ChipGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/ai_summary_base_url_input_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:hint="Base URL">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/ai_summary_base_url_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans"
                android:imeOptions="actionDone"
                android:inputType="textUri"
                android:singleLine="true"
                android:textColor="?attr/storyColorNormal"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
