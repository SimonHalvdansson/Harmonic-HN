<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="24dp"
    android:paddingTop="4dp"
    android:paddingRight="24dp"
    android:paddingBottom="4dp">

    <FrameLayout
        android:id="@+id/add_bookmarks_to_favorites_animation"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:importantForAccessibility="no">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/add_bookmarks_to_favorites_bookmark_target"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="start|center_vertical"
            app:cardBackgroundColor="?attr/colorSecondaryContainer"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp"
                android:src="@drawable/ic_bookmark"
                app:tint="?attr/colorOnSecondaryContainer" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/add_bookmarks_to_favorites_favorite_target"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="end|center_vertical"
            app:cardBackgroundColor="?attr/colorSecondaryContainer"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="14dp"
                android:src="@drawable/ic_star_filled"
                app:tint="?attr/colorOnSecondaryContainer" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/add_bookmarks_to_favorites_story"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:alpha="0"
            android:src="@drawable/ic_newspaper"
            app:tint="?attr/colorPrimary" />

    </FrameLayout>

    <TextView
        android:id="@+id/add_bookmarks_to_favorites_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/product_sans"
        android:gravity="center_horizontal"
        android:textColor="?attr/storyColorDisabled"
        android:textSize="14sp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/add_bookmarks_to_favorites_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:indeterminate="false"
        android:visibility="visible"
        app:trackCornerRadius="2dp" />

</LinearLayout>
