<?xml version="1.0" encoding="utf-8"?>
<androidx.core.view.insets.ProtectionLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/list_protection"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/comments_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="6dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_newspaper" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/product_sans"
                android:text="Open a story"
                android:textColor="?attr/textColorHighlighted"
                android:textSize="26sp"
                android:textStyle="bold" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/webview_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="68dp">

            <View
                android:id="@+id/comments_webview_backdrop"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:background="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/webview_download"
                style="@style/Widget.Material3Expressive.Button.IconButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Download file"
                android:textColor="?attr/storyColorNormal"
                android:visibility="gone"
                app:icon="@drawable/ic_file_download" />

            <ViewStub
                android:id="@+id/comments_webview_stub"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inflatedId="@+id/comments_webview_stub_content"
                android:layout="@layout/comments_webview" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/webview_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:waveAmplitude="1.5dp"
                app:waveSpeed="10dp"
                app:wavelength="40dp" />

        </FrameLayout>

        <LinearLayout
            android:id="@+id/comments_bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="16dp"
            android:orientation="vertical"
            app:behavior_hideable="false"
            app:layout_behavior="com.simon.harmonichackernews.SystemGestureSafeBottomSheetBehavior">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false">

                <androidx.swiperefreshlayout.widget.MaterialExpressiveSwipeRefreshLayout
                    android:id="@+id/comments_swipe_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/comments_recyclerview_swipe"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:scrollbars="vertical"
                        tools:listitem="@layout/comments_item" />

                </androidx.swiperefreshlayout.widget.MaterialExpressiveSwipeRefreshLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/comments_recyclerview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/comments_item" />

                <FrameLayout
                    android:id="@+id/comments_horizontal_inset_left"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="left"
                    android:importantForAccessibility="no"
                    android:visibility="gone">

                    <View
                        android:id="@+id/comments_horizontal_inset_left_tint"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <View
                        android:id="@+id/comments_horizontal_inset_left_fade"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                </FrameLayout>

                <FrameLayout
                    android:id="@+id/comments_horizontal_inset_right"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="right"
                    android:importantForAccessibility="no"
                    android:visibility="gone">

                    <View
                        android:id="@+id/comments_horizontal_inset_right_tint"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <View
                        android:id="@+id/comments_horizontal_inset_right_fade"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                </FrameLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/comments_scroll_navigation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/overlayButtonColor"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="8dp"
                    app:cardUseCompatPadding="false"
                    app:strokeColor="?attr/overlayButtonOutlineColor"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageButton
                            android:id="@+id/comments_scroll_previous"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:contentDescription="Previous top-level comment"
                            android:paddingLeft="8dp"
                            android:src="@drawable/ic_keyboard_arrow_up_dark" />

                        <ImageView
                            android:id="@+id/comments_scroll_icon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginLeft="10dp"
                            android:layout_marginTop="14dp"
                            android:layout_marginRight="10dp"
                            android:contentDescription="@null"
                            android:importantForAccessibility="no"
                            android:src="@drawable/ic_explore_dark" />

                        <ImageButton
                            android:id="@+id/comments_scroll_next"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:background="?selectableItemBackgroundBorderless"
                            android:contentDescription="Next top-level comment"
                            android:paddingRight="8dp"
                            android:src="@drawable/ic_keyboard_arrow_down_dark" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                    android:id="@+id/comments_search_scroll_top_fab"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="16dp"
                    android:layout_marginBottom="16dp"
                    android:backgroundTint="?attr/overlayButtonColor"
                    android:elevation="4dp"
                    android:fontFamily="@font/product_sans"
                    android:paddingLeft="24dp"
                    android:paddingRight="24dp"
                    android:text="Scroll to top"
                    android:textAllCaps="false"
                    android:textColor="#fff"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:icon="@drawable/ic_arrow_upward"
                    app:iconTint="#fff" />
            </FrameLayout>
        </LinearLayout>

        <FrameLayout
            android:id="@+id/comments_fullscreen_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/black"
            android:visibility="gone" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</androidx.core.view.insets.ProtectionLayout>
