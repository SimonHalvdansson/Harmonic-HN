<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/comments_empty"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="230dp"
        android:orientation="vertical">

        <ImageView
            android:layout_gravity="center_horizontal"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="6dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_action_news" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="26sp"
            android:text="Open a story"
            android:textStyle="bold"
            android:textColor="?attr/textColorHighlighted"
            android:fontFamily="@font/product_sans"
            android:layout_gravity="center_horizontal"  />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/webview_container"
        android:layout_marginBottom="68dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <View
            android:id="@+id/comments_webview_backdrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/white"
            android:alpha="0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/webview_download"
            style="@style/Widget.Material3Expressive.Button.IconButton.Outlined"
            app:icon="@drawable/ic_action_download"
            android:visibility="gone"
            android:textColor="?attr/storyColorNormal"
            android:text="Download file"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"/>

        <ViewStub
            android:id="@+id/comments_webview_stub"
            android:inflatedId="@+id/comments_webview_stub_content"
            android:layout="@layout/comments_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/webview_progress"
            app:waveAmplitude="1.5dp"
            app:wavelength="40dp"
            app:waveSpeed="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/comments_bottom_sheet"
        app:behavior_hideable="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:elevation="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false">

            <androidx.swiperefreshlayout.widget.MaterialExpressiveSwipeRefreshLayout
                android:id="@+id/comments_swipe_refresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/comments_recyclerview_swipe"
                    tools:listitem="@layout/comments_item"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"       />

            </androidx.swiperefreshlayout.widget.MaterialExpressiveSwipeRefreshLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/comments_recyclerview"
                tools:listitem="@layout/comments_item"
                android:clipToPadding="false"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"       />

            <com.google.android.material.card.MaterialCardView
                android:visibility="gone"
                android:id="@+id/comments_scroll_navigation"
                android:layout_marginBottom="16dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="?attr/overlayButtonColor"
                app:cardCornerRadius="28dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true"
                app:strokeColor="?attr/overlayButtonOutlineColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/comments_scroll_previous"
                        android:background="?selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_action_caret_up_white"
                        android:contentDescription="Previous top-level comment"
                        android:paddingLeft="8dp"
                        android:layout_width="56dp"
                        android:layout_height="56dp"/>

                    <ImageView
                        android:id="@+id/comments_scroll_icon"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_marginTop="14dp"
                        android:src="@drawable/ic_action_explore_white"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:layout_width="28dp"
                        android:layout_height="28dp"    />

                    <ImageButton
                        android:id="@+id/comments_scroll_next"
                        android:background="?selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_action_caret_down_white"
                        android:contentDescription="Next top-level comment"
                        android:paddingRight="8dp"
                        android:layout_width="56dp"
                        android:layout_height="56dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                android:id="@+id/comments_search_scroll_top_fab"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="?attr/overlayButtonColor"
                android:elevation="4dp"
                android:fontFamily="@font/product_sans"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:text="Scroll to top"
                android:textAllCaps="false"
                android:textColor="#fff"
                android:textStyle="bold"
                android:visibility="gone"
                app:icon="@drawable/ic_action_arrow_up"
                app:iconTint="#fff" />
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/comments_fullscreen_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
