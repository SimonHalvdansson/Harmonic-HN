<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/story_container"
    android:orientation="vertical"
    android:baselineAligned="false">

    <ImageView
        android:id="@+id/story_preview_image_large"
        android:layout_width="match_parent"
        android:layout_height="176dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/story_preview_image_background"
        android:clipToOutline="true"
        android:contentDescription="@null"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        android:visibility="gone"
        tools:src="@drawable/web_preview"
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/story_comment_layout"
        android:background="?selectableItemBackground"
        android:paddingEnd="6dp"
        android:paddingStart="6dp"
        android:layout_width="60dp"
        android:paddingTop="12dp"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/story_comments_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_action_comment"   />

        <TextView
            android:text="18"
            android:fontFamily="@font/product_sans"
            android:textStyle="bold"
            android:textColor="?attr/storyColorNormal"
            android:id="@+id/story_comments"
            android:gravity="center_horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"    />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/story_link_layout"
        android:background="?selectableItemBackground"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingRight="10dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:baselineAligned="true"
        android:orientation="horizontal">

        <TextView
            android:visibility="gone"
            android:layout_marginLeft="-7dp"
            android:layout_marginRight="-15dp"
            android:id="@+id/story_index"
            android:textColor="?attr/storyColorNormal"
            android:layout_width="43dp"
            android:gravity="center"
            android:layout_height="wrap_content"
            android:textSize="16dp"
            android:text="3." />

        <com.simon.harmonichackernews.utils.StoryTitleBaselineLayout
            android:orientation="vertical"
            android:paddingLeft="4dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">

            <com.facebook.shimmer.ShimmerFrameLayout
                android:layout_width="wrap_content"
                app:shimmer_duration="2000"
                app:shimmer_base_color="?attr/drawableColor"
                app:shimmer_base_alpha="0.15"
                app:shimmer_highlight_alpha="0.17"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:visibility="gone"
                    android:id="@+id/story_title_shimmer"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <View
                        android:layout_marginBottom="4dp"
                        android:layout_width="230dp"
                        android:background="@drawable/smooth_rectangle_drawable"
                        android:layout_height="22dp"/>

                    <View
                        android:layout_marginTop="1dp"
                        android:id="@+id/story_title_shimmer_meta"
                        android:layout_width="135dp"
                        android:background="@drawable/smooth_rectangle_drawable"
                        android:layout_height="15dp"/>

                </LinearLayout>

            </com.facebook.shimmer.ShimmerFrameLayout>

            <TextView
                android:id="@+id/story_title"
                android:layout_width="match_parent"
                android:text="Algorithm breaks speed limit for solving linear equations"
                android:layout_height="wrap_content"
                android:layout_marginEnd="2dp"
                android:textSize="17.5sp"
                android:textColor="?attr/storyColorNormal"
                android:fontFamily="@font/product_sans"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_marginTop="1dp"
                android:id="@+id/story_meta_container"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_marginTop="0.5dp"
                    android:id="@+id/story_meta_favicon"
                    android:background="@drawable/favicon_thumbnail_background"
                    android:clipToOutline="true"
                    android:src="@drawable/ic_action_web"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:layout_marginRight="4dp"
                    android:layout_width="17dp"
                    android:layout_height="17dp"    />

                <TextView
                    android:id="@+id/story_meta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginTop="2dp"
                    android:textColor="?attr/textColorDefault"
                    android:text="53 points • quantamagazine.org • 2h"
                    android:fontFamily="@font/product_sans"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.simon.harmonichackernews.utils.StoryTitleBaselineLayout>

        <ImageView
            android:id="@+id/story_preview_image_small"
            android:layout_width="72dp"
            android:layout_height="54dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="2dp"
            android:background="@drawable/story_preview_image_background"
            android:clipToOutline="true"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:src="@drawable/web_preview"
            tools:visibility="visible" />
    </LinearLayout>

    </LinearLayout>

</LinearLayout>
