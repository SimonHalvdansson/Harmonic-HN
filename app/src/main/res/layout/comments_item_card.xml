<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingStart="@dimen/comment_card_shadow_padding"
    android:paddingTop="@dimen/comment_card_shadow_padding"
    android:paddingEnd="@dimen/comment_card_shadow_padding"
    android:paddingBottom="@dimen/comment_card_shadow_padding">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/comment_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:cardCornerRadius="8dp"
        app:cardElevation="1dp"
        app:strokeColor="?attr/commentDividerColor"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:id="@+id/comment_indent_indicator"
                android:layout_width="3.5dp"
                android:layout_height="match_parent"
                android:layout_marginRight="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="6dp"
                android:paddingTop="7dp"
                android:paddingRight="8dp"
                android:paddingBottom="7dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="2dp">

                    <TextView
                        android:id="@+id/comment_by"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/product_sans_bold"
                        android:textColor="?attr/storyColorDisabled"
                        android:textSize="13sp"
                        tools:text="eanzenberg" />

                    <TextView
                        android:id="@+id/comment_by_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:fontFamily="@font/product_sans"
                        android:textColor="?attr/storyColorDisabled"
                        android:textSize="13sp"
                        tools:text="7 hrs ago" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="right">

                        <TextView
                            android:id="@+id/comment_hidden_short"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:fontFamily="@font/product_sans"
                            android:maxLines="1"
                            android:paddingRight="4dp"
                            android:textColor="?attr/storyColorDisabled"
                            android:textSize="13sp"
                            android:visibility="visible"
                            tools:text="Hidden comment preview" />

                        <TextView
                            android:id="@+id/comment_hidden_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="4dp"
                            android:background="@drawable/further_comments_drawable"
                            android:fontFamily="@font/product_sans"
                            android:paddingLeft="5dp"
                            android:paddingTop="1dp"
                            android:paddingRight="5dp"
                            android:paddingBottom="1dp"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            tools:text="+3" />

                    </LinearLayout>

                </LinearLayout>

                <org.sufficientlysecure.htmltextview.HtmlTextView
                    android:id="@+id/comment_body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/product_sans"
                    android:textColor="?attr/storyColorNormal"
                    android:textSize="15sp"
                    tools:text="Yes, I've come to the same conclusion. When interviewing ML engineers, I prefer to know they are exceptional programmers with passable knowledge of ML than the other way around." />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
