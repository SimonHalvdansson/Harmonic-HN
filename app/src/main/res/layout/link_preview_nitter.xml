<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/comments_header_nitter_container"
    android:layout_width="match_parent"
    android:visibility="gone"
    tools:visibility="visible"
    tools:layout_marginTop="100dp"
    android:layout_height="wrap_content">

    <org.sufficientlysecure.htmltextview.HtmlTextView
        android:id="@+id/comments_header_nitter_text"
        android:textColor="?attr/storyColorNormal"
        android:textSize="15sp"
        tools:text="This is a tweet"
        android:textIsSelectable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingBottom="4dp"
        android:fontFamily="@font/product_sans" />
    <FrameLayout
        android:id="@+id/comments_header_nitter_media_container"
        android:background="@drawable/rounded_corners"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        android:clipToOutline="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/comments_header_nitter_image"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:contentDescription="Tweet image" />

        <TextView
            android:id="@+id/comments_header_nitter_video_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|right"
            android:layout_margin="10dp"
            android:background="@drawable/nitter_video_label_background"
            android:fontFamily="@font/product_sans_bold"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:text="VIDEO"
            android:textColor="#fff"
            android:textSize="11sp"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_gravity="bottom"
            android:paddingBottom="12dp"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:src="@drawable/ic_calendar_today"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:layout_width="14dp"
                    android:layout_height="16dp"/>

                <TextView
                    android:id="@+id/comments_header_nitter_date"
                    android:fontFamily="@font/product_sans"
                    android:paddingLeft="2dp"
                    android:paddingRight="8dp"
                    android:text="Nov 3"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ImageView
                    android:id="@+id/comments_header_nitter_reply_image"
                    android:src="@drawable/ic_reply"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:layout_width="15dp"
                    android:layout_height="16dp"/>

                <TextView
                    android:id="@+id/comments_header_nitter_reply_count"
                    android:fontFamily="@font/product_sans"
                    android:paddingLeft="1dp"
                    android:paddingRight="7dp"
                    android:text="12"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/comments_header_nitter_reposts_image"
                    android:src="@drawable/ic_action_retweet"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:layout_width="15dp"
                    android:layout_height="16dp"/>

                <TextView
                    android:id="@+id/comments_header_nitter_reposts"
                    android:fontFamily="@font/product_sans"
                    android:paddingLeft="1dp"
                    android:paddingRight="8dp"
                    android:text="3,709"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <ImageView
                    android:id="@+id/comments_header_nitter_likes_image"
                    android:src="@drawable/ic_thumb_up_filled"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:layout_width="12dp"
                    android:layout_height="16dp"/>

                <TextView
                    android:id="@+id/comments_header_nitter_likes"
                    android:fontFamily="@font/product_sans"
                    android:paddingLeft="2dp"
                    android:paddingRight="4dp"
                    android:text="4,651"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/comments_header_nitter_button_open"
            android:fontFamily="@font/product_sans_bold"
            app:icon="@drawable/ic_link_preview_x"
            android:textSize="14sp"
            android:textColor="#eee"
            app:backgroundTint="#000"
            android:elevation="2dp"
            android:text="Open on X"
            android:layout_marginBottom="4dp"
            style="@style/Widget.Material3Expressive.Button.IconButton.Filled"
            android:layout_width="wrap_content"
            android:layout_gravity="right"
            app:iconPadding="16dp"
            android:layout_height="52dp"/>

    </LinearLayout>


</LinearLayout>
