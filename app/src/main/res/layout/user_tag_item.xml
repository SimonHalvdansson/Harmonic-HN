<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingLeft="24dp"
    android:paddingRight="8dp">

    <ImageView
        android:id="@+id/user_tag_item_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginRight="16dp"
        android:importantForAccessibility="no"
        android:src="@drawable/ic_account_circle"
        app:tint="?attr/drawableColor" />

    <TextView
        android:id="@+id/user_tag_item_text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:fontFamily="@font/product_sans"
        android:maxLines="2"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:textColor="?attr/storyColorNormal"
        android:textSize="16sp" />

    <ImageButton
        android:id="@+id/user_tag_item_edit"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Edit tag"
        android:padding="12dp"
        android:src="@drawable/ic_edit"
        app:tint="?attr/drawableColor" />

    <ImageButton
        android:id="@+id/user_tag_item_delete"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Delete tag"
        android:padding="12dp"
        android:src="@drawable/ic_close"
        app:tint="?attr/drawableColor" />

</LinearLayout>
