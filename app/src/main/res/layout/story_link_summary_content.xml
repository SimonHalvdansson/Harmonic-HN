<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/story_link_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/story_link_preview_container"
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/story_link_preview_shimmer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:importantForAccessibility="noHideDescendants"
                app:shimmer_base_alpha="0.16"
                app:shimmer_base_color="?attr/drawableColor"
                app:shimmer_duration="2000"
                app:shimmer_highlight_alpha="0.2">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/smooth_rectangle_drawable" />
            </com.facebook.shimmer.ShimmerFrameLayout>

            <ImageView
                android:id="@+id/story_link_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:visibility="invisible"
                tools:src="@drawable/web_preview"
                tools:visibility="visible" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/story_link_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/product_sans_bold"
                android:textColor="?attr/storyColorNormal"
                android:textSize="20sp"
                tools:text="How we scale PgBouncer in ClickHouse Managed Postgres" />

            <LinearLayout
                android:id="@+id/story_link_meta_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/story_link_favicon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_public" />

                <TextView
                    android:id="@+id/story_link_meta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/product_sans"
                    android:maxLines="2"
                    android:textColor="?attr/storyColorDisabled"
                    android:textSize="13sp"
                    tools:text="64 points • clickhouse.com • 3h" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="10dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/story_link_description_shimmer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:importantForAccessibility="noHideDescendants"
            app:shimmer_base_alpha="0.15"
            app:shimmer_base_color="?attr/drawableColor"
            app:shimmer_duration="2000"
            app:shimmer_highlight_alpha="0.18">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:background="@drawable/smooth_rectangle_drawable" />

                <View
                    android:layout_width="220dp"
                    android:layout_height="16dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/smooth_rectangle_drawable" />
            </LinearLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>

        <TextView
            android:id="@+id/story_link_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/product_sans"
            android:lineSpacingExtra="2dp"
            android:textColor="?attr/storyColorNormal"
            android:textIsSelectable="true"
            android:textSize="15sp"
            android:visibility="gone"
            tools:text="A short description extracted from the linked page."
            tools:visibility="visible" />

        <TextView
            android:id="@+id/story_link_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/product_sans"
            android:textColor="?attr/storyColorDisabled"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="A page preview could not be loaded."
            tools:visibility="visible" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:alpha="0.45"
            android:background="?attr/commentDividerColor" />

        <LinearLayout
            android:id="@+id/story_link_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/story_link_vote_slot"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="2dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageButton
                    android:id="@+id/story_link_vote"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_thumb_up"
                    app:tint="?attr/storyColorNormal" />

                <com.google.android.material.loadingindicator.LoadingIndicator
                    android:id="@+id/story_link_vote_loading"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:focusable="false"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorSize="28dp" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/story_link_read"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="2dp"
                android:background="?selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="center"
                android:src="@drawable/ic_visibility"
                app:tint="?attr/storyColorNormal" />

            <ImageButton
                android:id="@+id/story_link_bookmark"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="2dp"
                android:background="?selectableItemBackgroundBorderless"
                android:padding="12dp"
                android:scaleType="center"
                android:src="@drawable/ic_bookmark"
                app:tint="?attr/storyColorNormal" />

            <FrameLayout
                android:id="@+id/story_link_favorite_slot"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginEnd="2dp"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageButton
                    android:id="@+id/story_link_favorite"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_star"
                    app:tint="?attr/storyColorNormal" />

                <com.google.android.material.loadingindicator.LoadingIndicator
                    android:id="@+id/story_link_favorite_loading"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:focusable="false"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorSize="28dp" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/story_link_comments"
                style="@style/Widget.Material3Expressive.Button.ElevatedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="2dp"
                android:layout_weight="1"
                android:text="@string/link_summary_comments"
                android:textAllCaps="false"
                android:textColor="?attr/storyColorNormal"
                android:textSize="13sp"
                app:icon="@drawable/ic_comment"
                app:iconPadding="4dp"
                app:iconTint="?attr/storyColorNormal" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
