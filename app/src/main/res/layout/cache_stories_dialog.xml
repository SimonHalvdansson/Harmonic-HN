<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingLeft="24dp"
    android:paddingRight="24dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cache_stories_explanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"
            android:text="@string/cache_stories_explanation"
            android:textColor="?attr/storyColorNormal"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/product_sans"
                android:text="@string/cache_stories_count_label"
                android:textColor="?attr/storyColorNormal"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/cache_stories_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/product_sans_bold"
                android:textColor="?attr/storyColorNormal"
                android:textSize="14sp" />

        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/cache_stories_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:contentDescription="@string/cache_stories_slider_content_description"
            android:valueFrom="5"
            android:valueTo="200"
            android:stepSize="5"
            app:labelBehavior="floating"
            app:tickVisible="false" />

    </LinearLayout>
</ScrollView>
