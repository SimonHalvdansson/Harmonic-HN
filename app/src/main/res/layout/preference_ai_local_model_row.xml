<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ai_summary_local_model_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="2dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="7dp"
        android:paddingEnd="4dp"
        android:paddingBottom="7dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ai_summary_local_model_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/local_model_logo_background"
                android:clipToOutline="true"
                android:contentDescription="@null"
                android:padding="3dp"
                android:scaleType="fitCenter" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/ai_summary_local_model_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/product_sans_bold"
                    android:maxLines="1"
                    android:textColor="?attr/storyColorNormal"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/ai_summary_local_model_availability"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/product_sans"
                    android:maxLines="1"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/ai_summary_local_model_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/ai_summary_local_model_quantization"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/local_model_tag_quantization_background"
                        android:ellipsize="end"
                        android:fontFamily="@font/product_sans_bold"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:paddingStart="5dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="5dp"
                        android:paddingBottom="2dp"
                        android:textColor="?attr/colorOnTertiaryContainer"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/ai_summary_local_model_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/local_model_tag_size_background"
                        android:fontFamily="@font/product_sans_bold"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:paddingStart="5dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="5dp"
                        android:paddingBottom="2dp"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/ai_summary_local_model_framework"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/local_model_tag_framework_background"
                        android:fontFamily="@font/product_sans_bold"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:paddingStart="5dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="5dp"
                        android:paddingBottom="2dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="9sp" />

                </LinearLayout>

            </LinearLayout>

            <ImageButton
                android:id="@+id/ai_summary_local_model_action"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Download model"
                android:padding="9dp"
                android:src="@drawable/ic_file_download" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/ai_summary_local_model_download_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/ai_summary_local_model_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="38dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="6dp"
                android:max="100"
                android:visibility="gone" />

            <TextView
                android:id="@+id/ai_summary_local_model_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="38dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="6dp"
                android:fontFamily="@font/product_sans"
                android:textColor="?attr/secondaryTextColor"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
